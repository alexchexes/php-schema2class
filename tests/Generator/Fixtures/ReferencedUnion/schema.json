{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "A": {
      "enum": ["foo", "bar"],
      "type": "string"
    },
    "B": {
      "enum": ["baz", "quz"],
      "type": "string"
    },
    "C": {
      "anyOf": [
        {"$ref": "#/definitions/A"},
        {"$ref": "#/definitions/B"}
      ]
    },
    "MyObject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "foo": {"$ref": "#/definitions/C"}
      },
      "required": ["foo"]
    }
  }
}
